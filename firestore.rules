rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function tripExists(tripId) {
      return exists(/databases/$(database)/documents/trips/$(tripId));
    }

    function trip(tripId) {
      return get(/databases/$(database)/documents/trips/$(tripId)).data;
    }

    // Membership check used by every FK-linked collection (expenses,
    // itineraries, todos, restaurantBills). Requires the trip to already
    // exist — a doc referencing a non-existent tripId is always rejected.
    function isTripMember(tripId) {
      return isSignedIn()
        && tripId is string
        && tripExists(tripId)
        && request.auth.uid in trip(tripId).memberIds;
    }

    function isTripOwner(tripId) {
      return isSignedIn()
        && tripExists(tripId)
        && request.auth.uid == trip(tripId).ownerId;
    }

    // ── users/{uid} ──────────────────────────────────────────────────────
    // Intentionally private: no other client ever queries this collection.
    // Anything a trip co-member needs to see (name, avatar) is denormalized
    // into trip.members instead — see schema-design.md.

    match /users/{userId} {
      allow read: if isSelf(userId);

      allow create: if isSelf(userId)
        && request.resource.data.uid == userId
        && request.resource.data.email is string
        && request.resource.data.displayName is string;

      allow update: if isSelf(userId)
        && request.resource.data.uid == userId
        // uid and createdAt are immutable once set
        && request.resource.data.uid == resource.data.uid;

      allow delete: if false; // account deletion handled via a trusted backend flow
    }

    // ── trips/{tripId} ───────────────────────────────────────────────────

    match /trips/{tripId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.memberIds;

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.memberIds is list
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.budget is number
        && request.resource.data.budget >= 0;

      // Any current member can update trip fields (e.g. adding a friend,
      // editing the budget), but nobody can hijack ownership or remove the
      // owner from membership through a normal update.
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.memberIds
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.ownerId in request.resource.data.memberIds;

      allow delete: if isTripOwner(tripId);
    }

    // ── expenses/{expenseId} ─────────────────────────────────────────────

    match /expenses/{expenseId} {
      allow read: if isTripMember(resource.data.tripId);

      allow create: if isTripMember(request.resource.data.tripId)
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.splitAmong is list
        && request.resource.data.splitAmong.size() > 0;

      // tripId and createdBy are immutable after creation.
      allow update: if isTripMember(resource.data.tripId)
        && request.resource.data.tripId == resource.data.tripId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.amount is number
        && request.resource.data.amount > 0;

      // Any trip member can delete a shared expense (collaborative ledger,
      // mirrors Splitwise-style tools) — tighten to creator-or-owner-only
      // by replacing the `||` clause below if you'd rather lock this down.
      allow delete: if isTripMember(resource.data.tripId)
        && (request.auth.uid == resource.data.createdBy || isTripOwner(resource.data.tripId));
    }

    // ── itineraries/{itemId} ─────────────────────────────────────────────

    match /itineraries/{itemId} {
      allow read: if isTripMember(resource.data.tripId);

      allow create: if isTripMember(request.resource.data.tripId)
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0;

      allow update: if isTripMember(resource.data.tripId)
        && request.resource.data.tripId == resource.data.tripId
        && request.resource.data.createdBy == resource.data.createdBy;

      allow delete: if isTripMember(resource.data.tripId)
        && (request.auth.uid == resource.data.createdBy || isTripOwner(resource.data.tripId));
    }

    // ── todos/{todoId} ───────────────────────────────────────────────────

    match /todos/{todoId} {
      allow read: if isTripMember(resource.data.tripId);

      allow create: if isTripMember(request.resource.data.tripId)
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0;

      allow update: if isTripMember(resource.data.tripId)
        && request.resource.data.tripId == resource.data.tripId
        && request.resource.data.createdBy == resource.data.createdBy;

      // Low-stakes collaborative list — any member can clear a task.
      allow delete: if isTripMember(resource.data.tripId);
    }

    // ── restaurantBills/{billId} ─────────────────────────────────────────

    match /restaurantBills/{billId} {
      allow read: if isTripMember(resource.data.tripId);

      allow create: if isTripMember(request.resource.data.tripId)
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.totalAmount is number
        && request.resource.data.totalAmount >= 0;

      allow update: if isTripMember(resource.data.tripId)
        && request.resource.data.tripId == resource.data.tripId
        && request.resource.data.createdBy == resource.data.createdBy;

      allow delete: if isTripMember(resource.data.tripId)
        && (request.auth.uid == resource.data.createdBy || isTripOwner(resource.data.tripId));
    }

    // Deny everything else by default (implicit — Firestore denies any
    // path with no matching rule — stated here for clarity).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
